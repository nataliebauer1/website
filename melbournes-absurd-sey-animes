<!DOCTYPE html>
<html lang="en">
<head>
 <meta charset="UTF-8"> 
 <meta name="viewport" content="width=device-width,initial-scale=1.0">
 <title>Nat's Space - A Field Guide to Sticker Genres</title>
 <!-- ===========================
BASE STYLES
=========================== -->
<style>
* {
    margin-bottom: 20px;
    padding: 0;
    box-sizing: border-box;
}
html, body {
    font-family: Verdana, sans-serif;
    background: #f4f4f4;
    color: #000;
    line-height: 1.6;
    scroll-behavior: smooth;
    overflow-x: hidden; 
    max-width: 100%;
    margin: 0;
}
/* Headings */
h1, h2, h3 {
    font-family: Copperplate, "Copperplate Gothic Light", fantasy;
}
h1 {
    font-size: clamp(18.2rem, 20.5vw, 19.5rem);
    line-height: 1.15;
}
h2 {
    font-size: clamp(3rem, 6.5vw, 5.5rem);
    line-height: 1.15;
}
h3 {
    font-size: clamp(1.5rem, 3.65vw, 2.15rem);
    line-height: 1.15;
}
p {
  text-align: justify;
  hyphens: auto;
 margin-top: 0px;
}
span {
    display: block;
    text-align: right;
}
 .title-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0px;
}
figcaption {
    text-align: center;
    margin-top: 0px;
}
/* Center headings */
section h1,
section h2 {
    text-align: center;
    margin-bottom: 20px;
}
/* hyperlink format */
a {
    color: black;        
    text-decoration: underline;
  }
/* Layout helpers */
.container {
    width: 90%;
    max-width: 100vw;
    margin: 0 auto;
}
.slideshow-container {
    position: relative;
    display: grid;
    place-items: center;
    width: 90%;
    max-width: 1000px;
    margin: 0px auto 0 auto;
    border-radius: 0px;
    overflow: hidden;      /* important */
    background: #f4f4f4;
}
.slide {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
}
.slide img {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: 5px;
}
/* ===========================
      BLOG POSTS
=========================== */
.blog-post {
    background: #FFC5D3;
    padding: 20px;
    border-radius: 8px;
    margin-top: 10px;
}
/* ===========================
      FOOTER
=========================== */
footer {
    text-align: center;
    margin: 60px 0 30px;
    color: #000;
}
/* ===========================
      OUTLAY PC/mOBILE
=========================== */
@media (min-width: 1400px) {
    header {
        height: 70vh; /* more elegant framing on big screens */
    }
}
@media (max-width: 700px) {
    body {
        overflow-x: hidden;
    }
    .container {
        width: 92%;
    }
}
</style>
</head>
